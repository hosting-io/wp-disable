# Files and folders that must NOT be deployed to the WordPress.org SVN repo.
# Used by 10up/action-wordpress-plugin-deploy. Keep in sync with the EXCLUDES
# list in scripts/ship-wp-disable.sh.

# Version control / CI / dev tooling
/.git
/.github
# wp.org listing assets (icon/banner/screenshots) — published to SVN /assets by
# the deploy action, must NOT live inside the distributed plugin zip.
/.wordpress-org
/.gitignore
/.distignore
/.editorconfig
/phpcs.xml
/phpcs.xml.dist
/_config.yml

# Local-only helpers and build output
/scripts
/dist
/build
/node_modules
/.idea
/.sass-cache

# Project docs (developer-facing, not shipped to users)
/TODO.md
/CHANGELOG.md

# Local scratch / working notes
/to-add or fix

# OS cruft
.DS_Store
*/.DS_Store
